# ============================================
# SignalIQ — Environment Variables
# Copy this file to .env and fill in your keys
# ============================================

# Stream (getstream.io) — Video Edge Network
STREAM_API_KEY=your_stream_api_key_here
STREAM_API_SECRET=your_stream_api_secret_here

# Google AI Studio — Gemini Live (real-time LLM reasoning)
GOOGLE_API_KEY=your_google_api_key_here

# ElevenLabs — Text-to-Speech (whisper delivery)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Deepgram — Speech-to-Text (real-time transcription)
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Optional: HuggingFace (for model downloads)
# HF_TOKEN=your_huggingface_token_here
